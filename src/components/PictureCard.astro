---
type Props = {
  title: string;
  caption: string
  imageUrl: string;   
  bgUrl: string;      
  orientation?: "portrait" | "landscape";
  highlighted?: boolean;
};

const {title, caption, imageUrl, bgUrl, highlighted = false, orientation = "portrait"} = Astro.props;
---

<article
  class:list={[
    "card",
    orientation === "landscape" && "card--landscape",
    highlighted && "card--highlighted",
  ]}
  style={`background-image: url('${bgUrl}');`}
>
  <div class="card__inner">
    <div class="card__media">
      <img src={imageUrl} alt={title} loading="lazy" />
    </div>

    <div class="card__caption">
      {caption}
    </div>
  </div>

  <div class="card__overlay" aria-hidden="true"></div>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    color: rgb(255, 255, 255);
    background-size: cover;
    background-position: center;
    width: 255px;
    height: 360px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.12);
  }

  .card--landscape {
    width: 350px;
    height: 255px; 
    
  }

  .card__media {
    overflow: hidden;
    
  }

  .card__inner {
  position: relative;
  z-index: 1;
  height: 100%;
  padding: 28px;
  box-sizing: border-box;

  display: grid;
  grid-template-rows: 1fr auto; 
  gap: 14px;                   
}


.card__media {
  overflow: hidden;
}


.card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;        
  object-position: center;
  display: block;
}


.card__caption {
  height: 36px;             
  display: flex;
  align-items: center;
  justify-content: center; 
  font-weight: 700;
  color: white;
  opacity: 0.95;
}
</style>
