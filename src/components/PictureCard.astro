---
type Props = {
  title: string;
  imageUrl: string;   // rund drink
  bgUrl: string;      // orange bakgrunn (blob-bilde)
  highlighted?: boolean;
};

const {title, imageUrl, bgUrl, highlighted = false } = Astro.props;
---

<article
  class:list={[
    "card",
    highlighted && "card--highlighted",
  ]}
  style={`background-image: url('${bgUrl}');`}
>
  <div class="card__content">
    <div class="card__avatar">
      <img src={imageUrl} alt={title} loading="lazy" />
    </div>
  </div>

  <div class="card__overlay" aria-hidden="true"></div>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    padding: 2rem;
    color: rgb(255, 255, 255);
    background-size: cover;
    background-position: center;
    width: 255px;
    height: 360px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.12);
  }

  .card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .card__avatar {
    width: auto;
    height: auto;
    overflow: hidden;
    background: rgba(255,255,255,0.2);
  }

  .card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card__title {
    margin-top: 0.5rem;
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .card__price {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
  }

  .card__desc {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    line-height: 1.35;
    opacity: 0.92;
    max-width: 22ch;
  }

  .card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.08); /* for lesbarhet */
  }

  .card--highlighted {
    outline: 4px solid #3b82f6; /* blå markering */
    outline-offset: -4px;
  }
</style>
