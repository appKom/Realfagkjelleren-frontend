---
interface Props {
  title: string;
  description: string;
  imageUrl: string;
  bgUrl: string;
}

const { title, description, imageUrl, bgUrl } = Astro.props;
---

<article class="menu-card" style={`--bg-url: url(${bgUrl})`}>
  <div class="image-wrap">
    <img src={imageUrl} alt={title} loading="lazy" />
  </div>

  <div class="text">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
</article>

<style>
  .menu-card {
    width: 100%;
    max-width: 255px;
    min-height: 360px;
    border-radius: 24px;
    background-color: #ff6f00;
    background-image: var(--bg-url);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    box-sizing: border-box;
  }

  .image-wrap {
    width: 120px;
    height: 120px;
    border-radius: 999px;
    overflow: hidden;
    margin-top: 1.25rem;
    margin-bottom: 1.75rem;
    flex-shrink: 0;
  }

  .image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .text {
    color: white;
  }

  .text h2 {
    font-family: "Gantari", sans-serif;
    font-size: 2rem;
    line-height: 1.1;
    font-weight: 800;
    margin: 0 0 1.2rem 0;
  }

  .text p {
    font-family: "Gantari", sans-serif;
    font-size: 1rem;
    line-height: 1.45;
    font-weight: 700;
    margin: 0;
  }

  @media (max-width: 900px) {
    .menu-card {
      max-width: 340px;
      min-height: 360px;
    }

    .text h2 {
      font-size: 1.8rem;
    }
  }
</style>