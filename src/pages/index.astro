---
import Layout from '../layouts/Layout.astro';
import type Description from '../interfaces/description';
import type Title from '../interfaces/title';
import fetchApi from '../lib/strapi';

const home_page_description = await fetchApi<Description>({
  endpoint: 'descriptions/aifqgz2rbngl0222bnzy0ps9',
  wrappedByKey: 'data',
});

const home_page_titles = await fetchApi<Title[]>({
  endpoint: 'titles?filters[slug][$in][0]=for-studenter&filters[slug][$in][1]=av-studenter',
  wrappedByKey: 'data',
});
---

<Layout title="Realfagskjelleren" navbarTextColor="#FFFFFF">
  <main class="relative min-h-screen overflow-hidden bg-[#FE710F] text-white">
    <!-- Dekor -->
    <img
      src="/flekkV.svg"
      alt=""
      class="pointer-events-none absolute left-0 top-0 w-28 sm:w-40 md:w-52 lg:w-64"
    />
    <img
      src="/flekkOH.svg"
      alt=""
      class="pointer-events-none absolute right-0 top-0 w-32 sm:w-32 md:w-52 lg:w-52"
    />
    <img
      src="/flekkNH.svg"
      alt=""
      class="pointer-events-none absolute bottom-0 right-0 w-32 sm:w-40 md:w-52 lg:w-64"
    />

    <!-- Innhold -->
    <section class="relative z-10 mx-auto flex min-h-screen max-w-8xl flex-col items-center justify-start px-6 py-36 lg:py-32 text-center sm:px-8 lg:px-12 lg:mt-8">
      <h1 class="font-black leading-relaxed">
        <span class="block text-5xl md:text-[5rem] lg:text-7xl">
          {home_page_titles[0].Title}
        </span>
        <span class="block text-5xl md:mt-4 md:text-[5rem] lg:text-7xl">
          {home_page_titles[1].Title}
        </span>
      </h1>

      <p class="mt-8 max-w-[44ch] text-xl lg:text-2xl leading-7 sm:leading-9">
        <span class="block">Stedet for alle nerdene på realfagsbygget!</span>
        <span class="mt-10 block">{home_page_description.Description}</span>
      </p>

      <div class="mt-8">
        <a
          href="/events"
          class="inline-block rounded-full bg-white px-8 py-3 text-sm font-bold text-orange-500 transition hover:bg-orange-100 sm:px-10 sm:text-base"
        >
          SE HVA SOM SKJER
        </a>
      </div>
    </section>
  </main>
</Layout>