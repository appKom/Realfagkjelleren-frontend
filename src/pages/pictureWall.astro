---
import Layout from "../layouts/Layout.astro";
import PictureCard from "../components/PictureCard.astro";

const items = [
  {
    title: "Amaretto sour",
    imageUrl: "../public/togutter.png",
    bgUrl: "../public/cards_backgrounds/bg1.svg",
  },
  {
    title: "Moro",
    imageUrl: "/images/drinks/mojito.jpg",
    bgUrl: "../public/cards_backgrounds/bg2.svg",
  },
  {
    title: "Halloween",
    imageUrl: "/uma",
    bgUrl: "../public/cards_backgrounds/bg3.svg",
  },
  {
    title: "Valentine",
    imageUrl: "/uma",
    bgUrl: "../public/cards_backgrounds/bg4.svg",
  },
  {
    title: "17 Mai",
    imageUrl: "/uma",
    bgUrl: "../public/cards_backgrounds/bg5.svg",
  },  
  {
    title: "Oktoberfest",
    imageUrl: "/uma",
    bgUrl: "../public/cards_backgrounds/bg6.svg",
  },  
  {
    title: "Jul",
    imageUrl: "/uma",
    bgUrl: "../public/cards_backgrounds/bg7.svg",
  },
  {
    title: "Sjakk-rave",
    imageUrl: "/uma",
    bgUrl: "../public/cards_backgrounds/bg8.svg",
  },
  
];

---


<Layout title = "pictureWall" navbarTextColor="#FF5733">
    <main>
        <div class = "content">
            <h1 class = "pb-16 title">Bildevegg</h1>
            <section class="grid">
                {items.map((item, idx) => (
                    <PictureCard {...item} highlighted={idx === 3} />
                ))}
            </section>
        </div>
    </main>
</Layout>

<style>
  main {
		background-color: rgb(255, 255, 255);
		width: 100%;
		color: black;
		font-size: 20px;
		line-height: 1.6;
		min-height: 300vh; 
        font-family: 'Gantari', sans-serif;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 255px);
    gap: 3.5rem;
    justify-content: center; 
  }

  .content{
    padding-top: 11rem;
    padding-left: auto;
    padding-right: auto;
  }
  
  .title{
    color: #FE710F;
    font-size: 60px; 
    font-weight: bolder;
    text-align: center;
    line-height: 70px;
  }
</style>