---
import Layout from '../layouts/Layout.astro';
import type Title from '../interfaces/title';
import type Description from '../interfaces/description';
import fetchApi from '../lib/strapi';

const aboutUsData = await fetchApi({
  endpoint: 'about-us',
  wrappedByKey: 'data',
});

const om_oss_descriptions = await fetchApi<Description[]>({
  endpoint:
    'descriptions?filters[slug][$in][0]=description&filters[slug][$in][1]=description-1&filters[slug][$in][2]=description-2&filters[slug][$in][3]=description-3&filters[slug][$in][4]=description-4',
  wrappedByKey: 'data',
});

const om_oss_titles = await fetchApi<Title[]>({
  endpoint: 'titles?filters[slug][$in][0]=bar&filters[slug][$in][1]=historie',
  wrappedByKey: 'data',
});
---

<Layout title="Om Oss" navbarTextColor="#FF5733">
  <main class="relative overflow-hidden bg-[#f6f6f6] text-black font-['Gantari']">
    
    <img src="/flekk_omossOV.svg" alt="" class="pointer-events-none absolute top-0 left-0 w-40 md:w-40 lg:w-80" />
    <img src="/flekk_omossOH.svg" alt="" class="pointer-events-none absolute top-0 right-0 w-20 md:w-40 lg:w-40" />
    <img src="/flekk_omossMV.svg" alt="" class="pointer-events-none absolute left-0 top-[17%] sm:top-[18%] lg:top-[25%] w-32 md:w-52 lg:w-72 z-50" />
    <img src="/flekk_omossNH.svg" alt="" class="pointer-events-none absolute right-0 bottom-[26%] sm:bottom-[29%] lg:bottom-[30%] w-32 md:w-52 lg:w-72" />

    <section class="relative z-10 mx-auto mt-10 max-w-8xl px-6 sm:px-8 sm:mt-20 lg:px-12 pt-20 md:pt-0 pb-20">
      <!-- Hero -->
      <div class="grid lg:grid-cols-[auto_1fr] items-start lg:gap-20">
        <div class="mx-auto mt-16 order-2 lg:order-1 lg:mx-0">
          <img
            src="/bar_bilde.png"
            alt="bilde av baren"
            class="max-w-[465px] rounded-2xl object-cover shadow-sm"
          />
        </div>

        <div class="order-1 lg:order-2">
          <h1 class="max-w-[12ch] text-4xl font-black uppercase text-orange-500 pt-10 sm:text-5xl lg:text-6xl lg:leading-[4.5rem]">
            {om_oss_titles[0].Title}
          </h1>

          <h2 class="pt-6 text-2xl font-bold leading-snug text-[#703319] sm:text-3xl lg:text-4xl lg:max-w-md">
            Baren er drevet av studenter, for studenter
          </h2>

          <p class="pt-6 max-w-[60ch] text-base leading-8 sm:text-lg">
            {om_oss_descriptions[0].Description}
          </p>
        </div>
      </div>

      <!-- Historie -->
      <section class="mt-16 max-w-3xl justify-start lg:mt-36 lg:ml-36">
        <h2 class="text-4xl font-extrabold leading-tight text-[#FE710F] sm:text-5xl lg:text-6xl">
          {om_oss_titles[1].Title}
        </h2>

        <div class="mt-8 space-y-6 text-lg leading-8 sm:text-lg lg:leading-10">
          <p>{om_oss_descriptions[1].Description}</p>
          <p>{om_oss_descriptions[2].Description}</p>
          <p>{om_oss_descriptions[3].Description}</p>
          <p>{om_oss_descriptions[4].Description}</p>
        </div>
      </section>
    </section>

    <!-- Kontakt + kart -->
    <section class="relative z-10 grid grid-cols-1 lg:grid-cols-2 lg: mt-36">
      <div class="bg-orange-500 px-6 py-10 text-white sm:px-8 lg:px-12 lg:py-14">
        <h2 class="max-w-[20ch] text-3xl font-bold leading-tight sm:text-4xl">
          Vi holder til i kjellerne på Moholt
        </h2>

        <p class="pt-5 text-lg">Du kan nå oss på:</p>

        <div class="pt-7 space-y-4 text-base sm:text-lg">
          <p>📍 Herman Krags veg 12</p>
          <p>📞 +47 XXX XX XXX</p>
          <p>✉️ styret@realfagskjelleren.no</p>
        </div>
      </div>

      <div class="min-h-[320px] lg:min-h-[420px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1785.7022235017685!2d10.42997587741302!3d63.412449176842514!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x466d316c62e31a7d%3A0x5747cb25f1aec13b!2sRealfagskjelleren!5e0!3m2!1sno!2sno!4v1760879418426!5m2!1sno!2sno"
          class="h-full w-full"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </section>

    <!-- Sosiale medier -->
    <section class="relative z-10 px-6 py-16 text-center sm:px-8 lg:px-12">
      <h2 class="text-3xl font-extrabold text-[#FE710F] sm:text-4xl">
        Følg oss på sosiale medier!
      </h2>

      <div class="mt-6 flex justify-center gap-5">
        <a href="https://www.facebook.com/Realfagskjelleren/?locale=nb_NO">
          <img src="/fb.svg" alt="facebook logo" class="h-10 w-10 sm:h-12 sm:w-12" />
        </a>
        <a href="https://www.instagram.com/realfagskjelleren/">
          <img src="/ig.svg" alt="instagram logo" class="h-10 w-10 sm:h-12 sm:w-12" />
        </a>
      </div>
    </section>
  </main>
</Layout>